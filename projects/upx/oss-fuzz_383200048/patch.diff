From 78f4959521f24ce86b6226454dc84c2106595a15 Mon Sep 17 00:00:00 2001
From: John Reiser <jreiser@BitWagon.com>
Date: Sat, 15 Feb 2025 19:35:21 -0800
Subject: [PATCH] Fix de-compression of ELF shared libraries

Reset ph.method on each b_info.b_method.
Use file_image[] as ReadOnly, subsuming fi->seek()+read().
Use lowmem[0, +xct_off) for changing values.
Work on un_DT_INIT().
https://github.com/upx/upx/issues/882

	modified:   p_lx_elf.cpp
	modified:   p_lx_elf.h
	modified:   p_unix.cpp
---
 src/p_lx_elf.cpp | 117 +++++++++++++++++------------------------------
 src/p_lx_elf.h   |   2 +-
 src/p_unix.cpp   |   2 +
 3 files changed, 46 insertions(+), 75 deletions(-)

diff --git a/src/p_lx_elf.cpp b/src/p_lx_elf.cpp
index 66999e20..491c7458 100644
--- a/src/p_lx_elf.cpp
+++ b/src/p_lx_elf.cpp
@@ -5357,17 +5357,18 @@ unsigned PackLinuxElf::pack2_shlib_overlay_write(OutputFile *fo, MemBuffer &mb,
 // Returns compressed size
 unsigned PackLinuxElf::pack2_shlib_overlay_compress(
     MemBuffer &bufo,
-    MemBuffer &bufi,
+    upx_byte const *inp,
     unsigned u_len
 )
 {
     ph.saved_u_adler = ph.u_adler;
-    ph.u_adler = upx_adler32(bufi, ph.u_len, ph.saved_u_adler);
+    ph.u_adler = upx_adler32(inp, u_len, ph.saved_u_adler);
+    ph.u_len += u_len;
 
     unsigned const method = (EM_ARM == e_machine) ? M_NRV2B_8 : M_NRV2B_LE32;
     methods_used |= 1 << method;
     unsigned c_len = 0;
-    int r = upx_compress(bufi, u_len, bufo, &c_len,
+    int r = upx_compress(inp, u_len, bufo, &c_len,
         /* &progress callback */ nullptr,
         method, 10,
         /* &config_t */ nullptr, /* &result_t */ nullptr);
@@ -5377,7 +5378,8 @@ unsigned PackLinuxElf::pack2_shlib_overlay_compress(
         throwInternalError("header compression size increase");
 
     ph.saved_c_adler = ph.c_adler;
-    ph.c_adler = upx_adler32(bufo, ph.c_len, ph.saved_c_adler);
+    ph.c_adler = upx_adler32(bufo,  c_len, ph.saved_c_adler);
+    ph.c_len += c_len;
     return c_len;
 }
 
@@ -5387,7 +5389,7 @@ unsigned PackLinuxElf::pack2_shlib_overlay_compress(
