From aa5af8d041521507f8bc8ded8a365ee56098388c Mon Sep 17 00:00:00 2001
From: Garret Rieger <grieger@google.com>
Date: Tue, 23 Oct 2018 15:45:35 -0700
Subject: [PATCH] Fix size calculation in DEFINE_SIZE_ARRAY_SIZED.

---
 src/hb-machinery.hh | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/hb-machinery.hh b/src/hb-machinery.hh
index ae34c92..19245e8 100644
--- a/src/hb-machinery.hh
+++ b/src/hb-machinery.hh
@@ -118,7 +118,7 @@ static inline Type& StructAfter(TObject &X)
 
 #define DEFINE_SIZE_ARRAY_SIZED(size, array) \
 	DEFINE_SIZE_ARRAY(size, array); \
-	inline unsigned int get_size (void) const { return (size - array[0].min_size + array.get_size ()); }
+	inline unsigned int get_size (void) const { return (size - array.min_size + array.get_size ()); }
 
 #define DEFINE_SIZE_ARRAY2(size, array1, array2) \
   DEFINE_INSTANCE_ASSERTION (sizeof (*this) == (size) + sizeof (this->array1[0]) + sizeof (this->array2[0])); \
-- 
2.7.4

