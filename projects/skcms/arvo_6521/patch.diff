 profiles/fuzz/a2b_too_many_input_channels.icc | Bin 0 -> 2124 bytes
 src/ICCProfile.c                              |   7 ++++---
 tests.c                                       |   1 +
 3 files changed, 5 insertions(+), 3 deletions(-)
 create mode 100644 profiles/fuzz/a2b_too_many_input_channels.icc

diff --git a/profiles/fuzz/a2b_too_many_input_channels.icc b/profiles/fuzz/a2b_too_many_input_channels.icc
new file mode 100644
index 0000000000000000000000000000000000000000..506518d1cbd7d35374a41092ac7fdd08ead435dc
GIT binary patch
