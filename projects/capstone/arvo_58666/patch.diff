+		mnem_len = sizeof(MI->flat_insn->mnemonic) - 1;
+
+	memset(MI->flat_insn->mnemonic, 0, sizeof(MI->flat_insn->mnemonic));
+	strncpy(MI->flat_insn->mnemonic, O->buffer, mnem_len);
 }
 
