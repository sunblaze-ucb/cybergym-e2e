+++ b/src/lib/libdwarf/dwarf_debuglink.c
@@ -75,10 +75,18 @@ is_full_path(char *path,int joinchar)
 {
     unsigned char c = path[0];
     unsigned char c1 = 0;
+    if (!c) {
+        /* empty string. */
+        return FALSE;
+    }
     if (c == joinchar) {
         return TRUE;
     }
     c1 = path[1];
+    if (!c1) {
+        /* No second character */
+        return FALSE;
+    }
     if (c1 == ':') {
