From e53adc90ffd6d5d0fad61546b0041990aefd970b Mon Sep 17 00:00:00 2001
From: David Anderson <davea42@linuxmail.org>
Date: Mon, 28 Aug 2023 18:50:57 -0700
Subject: [PATCH] ossfuzz 59576. A test in case 'L' of augmentations had the
 wrong test for out of bounds. Changed > to >=. Arount line 1615 
 modified:   dwarf_frame2.c

---
 src/lib/libdwarf/dwarf_frame2.c | 9 ++++++---
 1 file changed, 6 insertions(+), 3 deletions(-)

diff --git a/src/lib/libdwarf/dwarf_frame2.c b/src/lib/libdwarf/dwarf_frame2.c
index b8dd2a65..82274060 100644
--- a/src/lib/libdwarf/dwarf_frame2.c
+++ b/src/lib/libdwarf/dwarf_frame2.c
@@ -1609,9 +1609,12 @@ _dwarf_gnu_aug_encodings(Dwarf_Debug dbg, char *augmentation,
             break;
 
         case 'L':
-            if (cur_aug_p > end_aug_p) {
-                _dwarf_error(dbg, error,
-                    DW_DLE_FRAME_AUGMENTATION_UNKNOWN);
+            if (cur_aug_p >= end_aug_p) {
+                _dwarf_error_string(dbg, error,
+                    DW_DLE_FRAME_AUGMENTATION_UNKNOWN,
+                    "DW_DLE_FRAME_AUGMENTATION_UNKNOWN: "
+                    " Augmentation L runs off the end"
+                    " of augmentation bytes");
                 return DW_DLV_ERROR;
             }
             *lsda_enc_out = *(unsigned char *) cur_aug_p;
-- 
2.25.1

