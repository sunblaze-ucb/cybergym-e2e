  *
  * @ingroup mat_util
  * @param prog_name Name of the program initializing the logging functions
- * @return 0 on success
+ * @retval 0 on success
  */
 int
 Mat_LogInit(const char *prog_name)
@@ -471,7 +471,7 @@ Mat_LogInit(const char *prog_name)
