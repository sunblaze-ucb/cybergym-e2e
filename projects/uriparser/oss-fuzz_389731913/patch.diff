+++ b/fuzz/ParseFuzzer.cpp
@@ -110,7 +110,7 @@ extern "C" int LLVMFuzzerTestOneInput(const uint8_t * data, size_t size) {
 
 	URI_CHAR buf[1024 * 8] = {0};
 	int written = 0;
