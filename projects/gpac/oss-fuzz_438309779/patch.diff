From 91f5e9735703008a5b83052d3ea93fbb643acd95 Mon Sep 17 00:00:00 2001
From: Aurelien David <aurelien.david@telecom-paristech.fr>
Date: Tue, 12 Aug 2025 12:10:35 +0200
Subject: [PATCH] fix 0d6b0c2: prevent double frees in AC4 clean list (#3311)

autofuzz bug yD-KR3uv3kbD2Q, KmxtX7BLBAYM-g, qA8onAkaqU_GdA
---
 src/odf/descriptors.c | 40 ++++++++++++++++++++++------------------
 1 file changed, 22 insertions(+), 18 deletions(-)

diff --git a/src/odf/descriptors.c b/src/odf/descriptors.c
index d0bc551f0..69bb05336 100644
--- a/src/odf/descriptors.c
+++ b/src/odf/descriptors.c
@@ -2426,41 +2426,45 @@ void gf_odf_ac4_cfg_clean_list(GF_AC4Config *cfg)
 	if (!cfg)
 		return;
 
+
 	if (cfg->stream.presentations) {
 
+		GF_List* groups_to_del = gf_list_new();
+
 		while ( (pres = gf_list_pop_back(cfg->stream.presentations)) ) {
 
 			if (pres->substream_groups) {
 
 				while ( (group = gf_list_pop_back(pres->substream_groups)) ) {
 
-					if (group->substreams) {
+					if (group && gf_list_find(groups_to_del, group) < 0)
+						gf_list_add(groups_to_del, group);
+
+				}
+				gf_list_del(pres->substream_groups);
 
-						for (s = 0; s < gf_list_count(group->substreams); s++) {
-							subs = gf_list_get(group->substreams, s);
-							if (!subs) {
-								continue;
-							}
+			}
+			gf_free(pres);
+		}
 
-							gf_free(subs);
-						}
-						gf_list_del(group->substreams);
+		while ( (group = gf_list_pop_back(groups_to_del)) ) {
+			if (group->substreams) {
 
+				for (s = 0; s < gf_list_count(group->substreams); s++) {
+					subs = gf_list_get(group->substreams, s);
+					if (!subs) {
+						continue;
 					}
-					gf_free(group);
 
-					// remove potential duplicates of group
-					s32 idx = 1;
-					while (idx>=0) {
-						idx = gf_list_find(pres->substream_groups, group);
-						if (idx>=0) gf_list_rem(pres->substream_groups, idx);
-					}
+					gf_free(subs);
 				}
-				gf_list_del(pres->substream_groups);
+				gf_list_del(group->substreams);
 
 			}
-			gf_free(pres);
+			gf_free(group);
+
 		}
+		gf_list_del(groups_to_del);
 
 		gf_list_del(cfg->stream.presentations);
 		cfg->stream.presentations = NULL;
-- 
2.25.1

