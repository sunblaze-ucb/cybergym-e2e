From f86dd15fb28335c36274d76fd98b5c8d49f4008a Mon Sep 17 00:00:00 2001
From: Chris Liddell <chris.liddell@artifex.com>
Date: Tue, 6 Sep 2022 15:10:19 +0100
Subject: [PATCH] oss-fuzz 51045: Bounds check available points in Ins_ISECT()

---
 base/ttinterp.c | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/base/ttinterp.c b/base/ttinterp.c
index 722369fb6..4429439bf 100644
--- a/base/ttinterp.c
+++ b/base/ttinterp.c
@@ -4068,7 +4068,8 @@ static int nInstrCount=0;
     if ( BOUNDS( b0, CUR.zp0.n_points ) ||
          BOUNDS( b1, CUR.zp0.n_points ) ||
          BOUNDS( a0, CUR.zp1.n_points ) ||
-         BOUNDS( a1, CUR.zp1.n_points ) )
+         BOUNDS( a1, CUR.zp1.n_points ) ||
+         BOUNDS( point, CUR.zp2.n_points) )
     {
       CUR.error = TT_Err_Invalid_Reference;
       return;
