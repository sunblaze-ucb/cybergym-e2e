From 329fa492271566a43f905edafb83dbce1b01a62a Mon Sep 17 00:00:00 2001
From: Ken Sharp <Ken.Sharp@artifex.com>
Date: Tue, 28 Jan 2025 13:15:44 +0000
Subject: [PATCH] OSS-fuzz 391934080

Corrupted font leading to an attempt to use an element off the stack
when no element has been pushed onto the stack.

Fix by checking to see that the stack pointer is within the stack
bounds, return an error if not.
---
 base/gstype1.c | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/base/gstype1.c b/base/gstype1.c
index b564b79b8..63ffde68c 100644
--- a/base/gstype1.c
+++ b/base/gstype1.c
@@ -1,4 +1,4 @@
-/* Copyright (C) 2001-2023 Artifex Software, Inc.
+/* Copyright (C) 2001-2025 Artifex Software, Inc.
    All Rights Reserved.
 
    This software is provided AS-IS with no warranty, either express or
@@ -438,6 +438,8 @@ gs_type1_interpret(gs_type1_state * pcis, const gs_glyph_data_t *pgd,
 
                             /* We must remember to pop both the othersubr # */
                             /* and the argument count off the stack. */
+                            if (!CS_CHECK_CSTACK_BOUNDS(csp, cstack))
+                                return_error(gs_error_invalidfont);
                             switch (*pindex = fixed2int_var(*csp)) {
                                 case 0:
                                     if (!CS_CHECK_CSTACK_BOUNDS(&csp[-4], cstack))
-- 
2.25.1

