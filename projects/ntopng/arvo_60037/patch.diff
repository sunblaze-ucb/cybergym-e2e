From 1878ba1edfdbb0767d7a282b46caf5ec07bdeaf0 Mon Sep 17 00:00:00 2001
From: Luca Deri <deri@ntop.org>
Date: Fri, 11 Aug 2023 11:42:56 +0200
Subject: [PATCH] Fixes Heab buffer overflow in IEC104Stats

---
 httpdocs/dist       | 2 +-
 src/IEC104Stats.cpp | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/httpdocs/dist b/httpdocs/dist
index 5071e8a63..006ef2677 160000
--- a/httpdocs/dist
+++ b/httpdocs/dist
@@ -1 +1 @@
-Subproject commit 5071e8a631198c731a0396e0c2fc445fcaf65eaa
+Subproject commit 006ef2677725bfcce5b05a0ec84fa013ddcd2fa6
diff --git a/src/IEC104Stats.cpp b/src/IEC104Stats.cpp
index 84990b816..982f56695 100644
--- a/src/IEC104Stats.cpp
+++ b/src/IEC104Stats.cpp
@@ -241,7 +241,7 @@ void IEC104Stats::processPacket(Flow *f, bool tx_direction,
 
           offset += len + 2 /* magic and len */;
 
-          if (len >= 6)
+          if((len >= 6) && ((offset + 6) <= payload_len))
             asdu = /* ntohs */ (*((u_int16_t *)&payload[4 + offset]));
           else
             asdu = 0;
-- 
2.25.1

