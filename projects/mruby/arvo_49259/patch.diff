From 2b074893723ebb335e6469c34caa2d8eac05d6ed Mon Sep 17 00:00:00 2001
From: "Yukihiro \"Matz\" Matsumoto" <matz@ruby.or.jp>
Date: Wed, 20 Jul 2022 14:27:02 +0900
Subject: [PATCH] codegen.c: keep stack space for block argument.

---
 mrbgems/mruby-compiler/core/codegen.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/mrbgems/mruby-compiler/core/codegen.c b/mrbgems/mruby-compiler/core/codegen.c
index f61b68536..bf91a9c41 100644
--- a/mrbgems/mruby-compiler/core/codegen.c
+++ b/mrbgems/mruby-compiler/core/codegen.c
@@ -1956,6 +1956,7 @@ gen_assignment(codegen_scope *s, node *tree, node *rhs, int sp, int val)
         pop();
         genop_2(s, OP_ARYPUSH, cursp(), 1);
       }
+      push(); pop();
       s->sp = call;
       if (mid == MRB_OPSYM_2(s->mrb, aref) && n == 2) {
         genop_1(s, OP_SETIDX, cursp());
-- 
