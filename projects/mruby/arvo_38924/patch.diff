From f85c50543b4ec93f327b9b064ea193493b046766 Mon Sep 17 00:00:00 2001
From: "Yukihiro \"Matz\" Matsumoto" <matz@ruby.or.jp>
Date: Mon, 20 Sep 2021 10:35:01 +0900
Subject: [PATCH] codegen.c (mrb_last_insn): no previous instruction on top.

---
 mrbgems/mruby-compiler/core/codegen.c | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/mrbgems/mruby-compiler/core/codegen.c b/mrbgems/mruby-compiler/core/codegen.c
index 48543bd7e..380cd9317 100644
--- a/mrbgems/mruby-compiler/core/codegen.c
+++ b/mrbgems/mruby-compiler/core/codegen.c
@@ -467,6 +467,10 @@ mrb_prev_pc(codegen_scope *s, const mrb_code *pc)
 static struct mrb_insn_data
 mrb_last_insn(codegen_scope *s)
 {
+  if (s->pc == 0) {
+    struct mrb_insn_data data = { OP_NOP, 0 };
+    return data;
+  }
   return mrb_decode_insn(&s->iseq[s->lastpc]);
 }
 
