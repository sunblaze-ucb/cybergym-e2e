From a6657afab9ffb258b01b3d6e485a86328bf4d40e Mon Sep 17 00:00:00 2001
From: "Yukihiro \"Matz\" Matsumoto" <matz@ruby.or.jp>
Date: Sun, 4 Jul 2021 00:08:17 +0900
Subject: [PATCH] codegen.c: jump address should be generated by
 `gen_jmpdst()`.

---
 mrbgems/mruby-compiler/core/codegen.c | 6 ++----
 1 file changed, 2 insertions(+), 4 deletions(-)

diff --git a/mrbgems/mruby-compiler/core/codegen.c b/mrbgems/mruby-compiler/core/codegen.c
index 5ab2f6180..16488cf33 100644
--- a/mrbgems/mruby-compiler/core/codegen.c
+++ b/mrbgems/mruby-compiler/core/codegen.c
@@ -444,15 +444,13 @@ genjmp2(codegen_scope *s, mrb_code i, uint16_t a, uint32_t pc, int val)
     gen_B(s, OP_EXT1);
     gen_B(s, i);
     gen_S(s, a);
-    pos = s->pc;
-    gen_S(s, pc);
   }
   else {
     gen_B(s, i);
     gen_B(s, (uint8_t)a);
-    pos = s->pc;
-    gen_jmpdst(s, pc);
   }
+  pos = s->pc;
+  gen_jmpdst(s, pc);
   return pos;
 }
 
-- 
