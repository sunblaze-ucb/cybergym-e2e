From bc9476e7caa75e0a258682f4dc3247a00fed5581 Mon Sep 17 00:00:00 2001
From: "Yukihiro \"Matz\" Matsumoto" <matz@ruby.or.jp>
Date: Fri, 4 Mar 2022 14:18:20 +0900
Subject: [PATCH] unpack.c: unpack_BER() did assume the string length is not
 zero.

---
 mrbgems/mruby-pack/src/pack.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/mrbgems/mruby-pack/src/pack.c b/mrbgems/mruby-pack/src/pack.c
index 1edaac93b..b150f5e16 100644
--- a/mrbgems/mruby-pack/src/pack.c
+++ b/mrbgems/mruby-pack/src/pack.c
@@ -414,6 +414,7 @@ unpack_BER(mrb_state *mrb, const unsigned char *src, int srclen, mrb_value ary,
   const unsigned char *p = src;
   const unsigned char *e = p + srclen;
 
+  if (srclen == 0) return 0;
   for (i=1; p<e; p++,i++) {
     if (n > (MRB_INT_MAX>>7)) {
       mrb_raise(mrb, E_RANGE_ERROR, "BER unpacking 'w' overflow");
-- 
